# ======================================================================
# AgentMute - environment template
# ----------------------------------------------------------------------
# Copy this file to `.env` and fill in only what you need.
# `.env` is gitignored. NEVER commit real keys.
# ======================================================================

# ----------------------------------------------------------------------
# 0G Galileo (settlement + storage + compute share the same testnet RPC)
# ----------------------------------------------------------------------
ZEROG_RPC_URL=https://evmrpc-testnet.0g.ai
ZEROG_CHAIN_ID=16602
ZEROG_PRIVATE_KEY=

# ----------------------------------------------------------------------
# Gensyn AXL transport
#   mock    = in-process HTTP mock bridge (default, demo only)
#   gensyn  = real AXL node + MCP router (run them yourself, see README)
# ----------------------------------------------------------------------
AXL_TRANSPORT=mock
AXL_API_URL=http://127.0.0.1:9002
AXL_ROUTER_URL=http://127.0.0.1:9003
AXL_PEER_ID=
GENSYN_AXL_PING_PEER_ID=
MCP_PORT=9102
MCP_CALLBACK_URL=

# ----------------------------------------------------------------------
# OTC participants shown in the Trader Console peer picker
#   Format: Label|peerId|pair1;pair2, Label|peerId|pair
# ----------------------------------------------------------------------
OTC_PARTICIPANTS=
NEXT_PUBLIC_OTC_PARTICIPANTS=

# ----------------------------------------------------------------------
# Settlement (on-chain DarkPoolSettlement.settle)
#   SETTLEMENT_AUTO_SUBMIT=true only after both makers have funded wallets
#   and ERC-20 approvals. Otherwise runtime stays in signed-simulation mode.
# ----------------------------------------------------------------------
SETTLEMENT_RPC_URL=
SETTLEMENT_SUBMITTER_PRIVATE_KEY=
SETTLEMENT_AUTO_SUBMIT=false
NEXT_PUBLIC_SETTLEMENT_ADDRESS=

# ----------------------------------------------------------------------
# Explorer links (0G Galileo defaults)
# ----------------------------------------------------------------------
NEXT_PUBLIC_EXPLORER_NAME=0G Galileo Chainscan
NEXT_PUBLIC_EXPLORER_TX_BASE_URL=https://chainscan-galileo.0g.ai/tx/
NEXT_PUBLIC_EXPLORER_ADDRESS_BASE_URL=https://chainscan-galileo.0g.ai/address/

# ----------------------------------------------------------------------
# Agent brain iNFT (AgentBrainINFT — minimal ERC-7857-style wrapper)
# ----------------------------------------------------------------------
NEXT_PUBLIC_AGENT_BRAIN_INFT_ADDRESS=
AGENT_BRAIN_INFT_TOKEN_ID=
AGENT_BRAIN_INFT_MINT_TX=
AGENT_BRAIN_STORAGE_TX=
INFT_RPC_URL=
INFT_PRIVATE_KEY=
INFT_CONTRACT_ADDRESS=
INFT_TOKEN_ID=
INFT_TO=
INFT_CLONE_FEE_WEI=0
INFT_ROYALTY_RECEIVER=
INFT_ROYALTY_BPS=500

# ----------------------------------------------------------------------
# Encrypted brain store
#   local = AES-GCM envelope on disk (demo)
#   0g    = upload envelope to 0G Storage, reference by root hash
# ----------------------------------------------------------------------
BRAINSTORE_PROVIDER=local
BRAINSTORE_LOCAL_DIR=.darkpool-storage/brains
BRAINSTORE_PASSPHRASE=
BRAINSTORE_BOOTSTRAP_ON_START=false
BRAINSTORE_PERSIST_MEMORY_EVENTS=true
BRAIN_ROOT_HASH=

# ----------------------------------------------------------------------
# 0G Storage (used when BRAINSTORE_PROVIDER=0g)
# ----------------------------------------------------------------------
ZEROG_STORAGE_RPC_URL=
ZEROG_STORAGE_INDEXER_RPC_URL=https://indexer-storage-testnet-turbo.0g.ai
ZEROG_STORAGE_SDK_PACKAGE=
ZEROG_STORAGE_FINALITY_REQUIRED=false
ZEROG_STORAGE_EXPECTED_REPLICA=1
ZEROG_STORAGE_SKIP_TX=false
ZEROG_STORAGE_SKIP_IF_FINALIZED=true
ZEROG_STORAGE_FEE_WEI=
ZEROG_STORAGE_GAS_PRICE_WEI=
ZEROG_STORAGE_GAS_LIMIT=
ZEROG_STORAGE_LOG_PROGRESS=true

# ----------------------------------------------------------------------
# 0G Compute (optional — falls back to deterministic local inference)
#   ZEROG_COMPUTE_PRIVATE_KEY is optional; falls back to ZEROG_PRIVATE_KEY.
# ----------------------------------------------------------------------
COMPUTE_PROVIDER=local
ZEROG_COMPUTE_RPC_URL=
ZEROG_COMPUTE_PRIVATE_KEY=
ZEROG_COMPUTE_PROVIDER_ADDRESS=0xa48f01287233509FD694a22Bf840225062E67836
ZEROG_COMPUTE_MODEL=qwen/qwen-2.5-7b-instruct
ZEROG_COMPUTE_VERIFY_RESPONSES=true

# ----------------------------------------------------------------------
# Live event bus (ws-hub.ts, consumed by the Trader Console live tape)
# ----------------------------------------------------------------------
WS_HUB_PORT=8787
WS_HUB_URL=http://127.0.0.1:8787/publish
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8787/ws

# ----------------------------------------------------------------------
# Optional per-agent signing keys for the demo agents (derived otherwise)
# ----------------------------------------------------------------------
AGENT_PRIVATE_KEY_AGENT_A=
AGENT_PRIVATE_KEY_AGENT_B=
AGENT_PRIVATE_KEY_AGENT_C=
